builtin.module {

  // Operation is wrapped in stream fusion group:
  // whole thing is wrapped in fusion group with block arguments:
  "stream.fusion_group"() ({
    ^bb0(%0: !stream.strensor<256(c2)x512(c0)xbf16, ["tile_0_0"]>,
         %1: !stream.strensor<512(c0)x2048(c1)xbf16, ["tile_0_0"]>,
         %2: !stream.strensor<512(c0)x2048(c1)xbf16, ["tile_0_0"]>,
         %3: !stream.strensor<2048(c1)x512(c3)xbf16, ["tile_0_0"]>,
         %out: !stream.strensor<256(c2)x512(c3)xbf16, ["tile_0_0"]>):


  // %0 = "stream.in_edge"() <{tensor = "input"}> : () -> !stream.strensor<256(c2)x512(c0)xbf16, []>
  // %1 = "stream.in_edge"() <{tensor = "weights_1"}> : () -> !stream.strensor<512(c0)x2048(c1)xbf16, []>
  // %2 = "stream.in_edge"() <{tensor = "weights_2"}> : () -> !stream.strensor<512(c0)x2048(c1)xbf16, []>
  // %3 = "stream.in_edge"() <{tensor = "weights_3"}> : () -> !stream.strensor<2048(c1)x512(c3)xbf16, []>

  // First matmul:

  // Inputs:
  //                                                  ----> constant "edges" consist of only the constant sizes of the full tensor
  %4 = "stream.transfer"(%0) : (!stream.strensor<256(c2)x512(c0)xbf16, ["tile_0_0"]>) 
                             -> !stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(a1)x2(a3)x4(t2)x32(k2)x32(k0)xbf16, ["tile_0_1"]>
//                                                                                  ^    ^
//                                                                                  |    | For transfer to memtile, spatial dimension is temporal (otherwise the tensor would exist on more than 1 tile)
//                                                                                  |
//                                                                                  | Other spatial loops are absent here (they do not need to be repeated because of broadcast support)

%8, %88 = "stream.transfer"(%4) : (!stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(a1)x2(a3)x4(t2)x32(k2)x32(k0)xbf16, ["tile_0_1"]>) 
                               -> (!stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(s1)x2(a3)x4(s2)x32(k2)x32(k0)xbf16, ["tile_0_2", "tile_0_3", "tile_0_4", "tile_0_5", "tile_1_2", "tile_1_3", "tile_1_4", "tile_1_5"]> ,
                                   !stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(s1)x2(a3)x4(s2)x32(k2)x32(k0)xbf16, ["tile_2_2", "tile_2_3", "tile_2_4", "tile_2_5", "tile_3_2", "tile_3_3", "tile_3_4", "tile_3_5"]> )
//                                  ^ Two results indicate the output of this    ^     ^    ^
//                                    same transfer is used twice on different   |     |    | For the second transfer, the spatial dimension is set to indicate this transfer goes from one source
//                                    cores.                                     |     |    | to many destinations (as enlisted by the target core allocations)
//                                                                               ______|
//                                                                                     | Other spatial loops are absent or spatial: as they are not relevant for this tensor,
//                                                                                     | spatial means the thransfer should be broadcast across this dimension.


  // Weights:
  %5 = "stream.transfer"(%1) : (!stream.strensor<512(c0)x2048(c1)xbf16, ["tile_0_0"]>) 
                             -> !stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(t1)x2(a3)x4(a2)x32(k0)x64(k1)xbf16, ["tile_0_1"]>
  %9 = "stream.transfer"(%5) : (!stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(t1)x2(a3)x4(a2)x32(k0)x64(k1)xbf16, ["tile_0_1"]>) 
                             -> !stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(s1)x2(a3)x4(s2)x32(k0)x64(k1)xbf16, ["tile_0_2", "tile_0_3", "tile_0_4", "tile_0_5", "tile_1_2", "tile_1_3", "tile_1_4", "tile_1_5"]>

  %12 = "stream.computation_node"(%8, %9) <{kernel = "matmul_bf16_bf16_32_32_64"}> : 
                               (!stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(s1)x2(a3)x4(s2)x32(k2)x32(k0)xbf16, ["tile_0_2", "tile_0_3", "tile_0_4", "tile_0_5", "tile_1_2", "tile_1_3", "tile_1_4", "tile_1_5"]>, 
                                !stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(s1)x2(a3)x4(s2)x32(k0)x64(k1)xbf16, ["tile_0_2", "tile_0_3", "tile_0_4", "tile_0_5", "tile_1_2", "tile_1_3", "tile_1_4", "tile_1_5"]>) 
                             -> !stream.strensor<2(t2)x16(t1)|8(a3)x16(t0)x2(s1)x2(a3)x4(s2)x32(k2)x64(k1)xbf16, ["tile_0_2", "tile_0_3", "tile_0_4", "tile_0_5", "tile_1_2", "tile_1_3", "tile_1_4", "tile_1_5"]>

  // Second matmul:
  %6 =  "stream.transfer"(%2) : (!stream.strensor<512(c0)x2048(c1)xbf16, ["tile_0_0"]>) 
                              -> !stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(t1)x2(a3)x4(a2)x32(k0)x64(k1)xbf16, ["tile_0_1"]>
  %10 = "stream.transfer"(%6) : (!stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(t1)x2(a3)x4(a2)x32(k0)x64(k1)xbf16, ["tile_0_1"]>)  
                              -> !stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(s1)x2(a3)x4(s2)x32(k0)x64(k1)xbf16, ["tile_2_2", "tile_2_3", "tile_2_4", "tile_2_5", "tile_3_2", "tile_3_3", "tile_3_4", "tile_3_5"]>

  %13 = "stream.computation_node"(%88, %10) <{kernel = "matmul_bf16_bf16_32_32_64"}> : 
                              (!stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(s1)x2(a3)x4(s2)x32(k2)x32(k0)xbf16, ["tile_2_2", "tile_2_3", "tile_2_4", "tile_2_5", "tile_3_2", "tile_3_3", "tile_3_4", "tile_3_5"]>, 
                               !stream.strensor<2(t2)x16(t1)x8(a3)x16(t0)|2(s1)x2(a3)x4(s2)x32(k0)x64(k1)xbf16, ["tile_2_2", "tile_2_3", "tile_2_4", "tile_2_5", "tile_3_2", "tile_3_3", "tile_3_4", "tile_3_5"]>) 
                            -> !stream.strensor<2(t2)x16(t1)|8(a3)x16(t0)x2(s1)x2(a3)x4(s2)x32(k2)x64(k1)xbf16, ["tile_2_2", "tile_2_3", "tile_2_4", "tile_2_5", "tile_3_2", "tile_3_3", "tile_3_4", "tile_3_5"]>

  // Join transfers: spatial loop turns into temporal loop
  %14 = "stream.transfer"(%12) : (!stream.strensor<2(t2)x16(t1)|8(a3)x16(t0)x2(s1)x2(a3)x4(s2)x32(k2)x64(k1)xbf16, ["tile_0_2", "tile_0_3", "tile_0_4", "tile_0_5", "tile_1_2", "tile_1_3", "tile_1_4", "tile_1_5"]>) 
                               -> !stream.strensor<2(t2)x16(t1)|8(a3)x16(a0)x2(t1)x2(a3)x4(s2)x32(k2)x64(k1)xbf16, ["tile_4_2", "tile_4_3", "tile_4_4", "tile_4_5"]>
  %15 = "stream.transfer"(%13) : (!stream.strensor<2(t2)x16(t1)|8(a3)x16(t0)x2(s1)x2(a3)x4(s2)x32(k2)x64(k1)xbf16, ["tile_2_2", "tile_2_3", "tile_2_4", "tile_2_5", "tile_3_2", "tile_3_3", "tile_3_4", "tile_3_5"]>) 
                               -> !stream.strensor<2(t2)x16(t1)|8(a3)x16(a0)x2(t1)x2(a3)x4(s2)x32(k2)x64(k1)xbf16, ["tile_5_2", "tile_5_3", "tile_5_4", "tile_5_5"]>
                               //                                        ^     ^
                               //                                        |     Spatial loop gets converted into temporal loop
                               //                                        | Reduction dim becomes absent after transfer

  // Silu:
  %16 = "stream.computation_node"(%14) <{kernel = "silu_bf16"}> : (
                                  !stream.strensor<2(t2)x16(t1)|8(a3)x16(a0)x2(t1)x2(a3)x4(s2)x32(k2)x64(k1)xbf16, ["tile_4_2", "tile_4_3", "tile_4_4", "tile_4_5"]>) 
                               -> !stream.strensor<2(t2)x16(t1)x8(a3)x16(a0)x2(t1)x2(a3)|4(s2)x32(k2)x64(k1)xbf16, ["tile_4_2", "tile_4_3", "tile_4_4", "tile_4_5"]>
//                                                                            ^
//                                                                            Order was different

  %17 = "stream.transfer"(%16) : (!stream.strensor<2(t2)x16(t1)x8(a3)x16(a0)x2(t1)x2(a3)|4(s2)x32(k2)x64(k1)xbf16, ["tile_4_2", "tile_4_3", "tile_4_4", "tile_4_5"]>) 
                               -> !stream.strensor<2(t2)x16(t1)x8(a3)x16(a0)x2(t1)x2(a3)|4(s2)x32(k2)x64(k1)xbf16, ["tile_5_2", "tile_5_3", "tile_5_4", "tile_5_5"]>

  // Elementwise mult:
  %18 = "stream.computation_node"(%17, %15) <{kernel = "eltwise_mul_bf16_scalar"}> : 
                                  (!stream.strensor<2(t2)x16(t1)x8(a3)x16(a0)x2(t1)x2(a3)|4(s2)x32(k2)x64(k1)xbf16, ["tile_5_2", "tile_5_3", "tile_5_4", "tile_5_5"]>, 
                                   !stream.strensor<2(t2)x16(t1)|8(a3)x16(a0)x2(t1)x2(a3)x4(s2)x32(k2)x64(k1)xbf16, ["tile_5_2", "tile_5_3", "tile_5_4", "tile_5_5"]>) 
                                -> !stream.strensor<2(t2)x16(t1)x8(a3)x16(a0)x2(t1)x2(a3)|4(s2)x32(k2)x64(k1)xbf16, ["tile_5_2", "tile_5_3", "tile_5_4", "tile_5_5"]>

  %19 = "stream.transfer"(%18) : (!stream.strensor<2(t2)x16(t1)x8(a3)x16(a0)x2(t1)x2(a3)|4(s2)x32(k2)x64(k1)xbf16, ["tile_5_2", "tile_5_3", "tile_5_4", "tile_5_5"]>) 
                               -> !stream.strensor<2(t2)x16(t1)|8(a3)x16(a0)x2(t1)x2(s3)x4(s2)x32(k2)x64(k1)xbf16, ["tile_6_2", "tile_6_3", "tile_6_4", "tile_6_5", "tile_7_2", "tile_7_3", "tile_7_4", "tile_7_5"]>
    //                                                                             ^
    //                                                                             Result of elementwise gets broadcasted over a3 dimension:

  // Final matmul:
  // weights:
  %7 = "stream.transfer"(%3)  : (!stream.strensor<2048(c1)x512(c3)xbf16, ["tile_0_0"]>) 
                              -> !stream.strensor<2(t2)x16(t1)x8(t3)x16(a0)x2(t1)|2(t3)x4(a2)x64(k1)x32(k3)xbf16, ["tile_1_1"]>

  %11 = "stream.transfer"(%7) : (!stream.strensor<2(t2)x16(t1)x8(t3)x16(a0)x2(t1)|2(t3)x4(a2)x64(k1)x32(k3)xbf16, ["tile_1_1"]>) 
                              -> !stream.strensor<2(t2)x16(t1)x8(t3)x16(a0)x2(t1)|2(s3)x4(s2)x64(k1)x32(k3)xbf16, ["tile_6_2", "tile_6_3", "tile_6_4", "tile_6_5", "tile_7_2", "tile_7_3", "tile_7_4", "tile_7_5"]>

  %20 = "stream.computation_node"(%19, %11) <{kernel = "matmul_bf16_bf16_32_64_32"}> : 
                              (!stream.strensor<2(t2)x16(t1)|8(a3)x16(a0)x2(t1)x2(s3)x4(s2)x32(k2)x64(k1)xbf16, ["tile_6_2", "tile_6_3", "tile_6_4", "tile_6_5", "tile_7_2", "tile_7_3", "tile_7_4", "tile_7_5"]>, 
                               !stream.strensor<2(t2)x16(t1)x8(t3)x16(a0)x2(t1)|2(s3)x4(s2)x64(k1)x32(k3)xbf16, ["tile_6_2", "tile_6_3", "tile_6_4", "tile_6_5", "tile_7_2", "tile_7_3", "tile_7_4", "tile_7_5"]>) 
                           ->  !stream.strensor<2(t2)x16(t1)|8(t3)x16(a0)x2(t1)x2(s3)x4(s2)x32(k2)x32(k3)xbf16, ["tile_6_2", "tile_6_3", "tile_6_4", "tile_6_5", "tile_7_2", "tile_7_3", "tile_7_4", "tile_7_5"]>

  %21 = "stream.transfer"(%20) : (!stream.strensor<2(t2)x16(t1)|8(t3)x16(a0)x2(t1)x2(s3)x4(s2)x32(k2)x32(k3)xbf16, ["tile_6_2", "tile_6_3", "tile_6_4", "tile_6_5", "tile_7_2", "tile_7_3", "tile_7_4", "tile_7_5"]>) 
                               -> !stream.strensor<2(t2)x16(a1)|8(t3)x16(a0)x2(a1)x2(s3)x4(t2)x32(k2)x32(k3)xbf16, ["tile_0_1", "tile_2_1"]>
//                                                                                         ^
//                                                                                         | Spatial turns into temporal here (= join)


// Copy out:
  %22 = "stream.transfer"(%21) : (!stream.strensor<2(t2)x16(a1)|8(t3)x16(a0)x2(a1)x2(s3)x4(t2)x32(k2)x32(k3)xbf16, ["tile_0_1", "tile_2_1"]>) 
                               -> !stream.strensor<256(c2)x512(c3)xbf16, ["tile_0_0"]>
  "stream.yield"(%22) : (!stream.strensor<256(c2)x512(c3)xbf16, ["tile_0_0"]>) -> ()

  }) : () -> ()
}
