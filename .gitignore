# result pickle files
*.pkl
*.pickle

# Generated run artifacts (plots, perfetto traces, MLIR codegen) are always written
# under outputs*/ -- ignore those trees wholesale instead of blanket-ignoring every
# *.json/*.png/*.html/*.mlir/*.svg, which forced a ! negation for each committed
# fixture (tests/golden_metrics.json, docs/source/images/*.svg).
outputs*/

# workload and mapping input files
stream/inputs/aie/workload/*.onnx
stream/inputs/testing/workload/*.onnx
# ...except the small committed CI fixtures (cleared weights — see make_2_conv.py / make_swiglu.py)
!stream/inputs/testing/workload/2conv_1_8_32_32_16_32_3.onnx
!stream/inputs/testing/workload/swiglu_1_16_32.onnx
stream/inputs/aie/mapping/*.yaml
stream/inputs/aie/mapping/*.yml

# planning artifacts
.planning/
# Claude tooling & specs are local-only: CLAUDE.md, .claude/skills/ and plan/ live in a
# separate private repo (stream-claude-skills) and are symlinked in, so they are not tracked
# here. Keeps main code-only; the plan/spec pack stays confidential.
/CLAUDE.md
/.claude/skills
/plan
# .claude/ personal files
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock

# CO metrics capture output (Phase 39 — regenerated by each test run, never committed)
metrics_current.json
